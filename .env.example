# MeshFlow environment configuration
# Copy to .env and fill in your values.  Never commit .env to version control.
# cp .env.example .env

# ── LLM providers ─────────────────────────────────────────────────────────────
# Set the provider(s) you use. MeshFlow auto-detects from available keys.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Server auth ───────────────────────────────────────────────────────────────
# Comma-separated API keys for the MeshFlow runtime server.
# Leave blank to disable auth (dev / MESHFLOW_MOCK mode only).
MESHFLOW_API_KEYS=

# Allowed CORS origins for the runtime server.
MESHFLOW_CORS_ORIGINS=*

# HMAC secret for outbound webhook signatures.
MESHFLOW_WEBHOOK_SECRET=change-me-in-production

# ── Persistence paths ─────────────────────────────────────────────────────────
# SQLite file for the run ledger.
# Use a PostgreSQL URL for production: postgresql://user:pass@host/db
MESHFLOW_LEDGER_PATH=meshflow_runs.db

# Agent registry database (meshflow registry publish/list/search)
MESHFLOW_REGISTRY_PATH=meshflow_registry.db

# Budget tracking database (meshflow budget set/status/list)
MESHFLOW_BUDGET_PATH=meshflow_budgets.db

# ── OpenTelemetry / Observability ─────────────────────────────────────────────
# Set to enable distributed tracing (Jaeger, Grafana Tempo, Honeycomb, etc.)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=meshflow
# Optional auth headers: OTEL_EXPORTER_OTLP_HEADERS=x-api-key=your-key

# Set to 1 for in-process span collection without OTLP export (local dev).
MESHFLOW_OTEL=

# ── Mock mode (testing / CI) ──────────────────────────────────────────────────
# Set to 1 to use EchoProvider — no LLM calls, no API keys required.
MESHFLOW_MOCK=

# ── Environmental optimizer (optional) ────────────────────────────────────────
# MESHFLOW_REGION=us-west-2
# MESHFLOW_CARBON_BUDGET_G=500

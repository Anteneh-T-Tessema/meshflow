# MeshFlow environment variables — copy to .env and fill in values
# cp .env.example .env

# ── LLM Provider (at least one required) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Observability (optional) ──────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=meshflow

# ── Database (optional — defaults to SQLite in-memory) ────────────────────────
# MESHFLOW_DB_URL=postgresql://user:pass@localhost:5432/meshflow

# ── Cross-run learning store (optional) ───────────────────────────────────────
# MESHFLOW_LEARNING_DB=./meshflow_learning.db

# ── Environmental optimizer (optional) ───────────────────────────────────────
# MESHFLOW_REGION=us-west-2
# MESHFLOW_CARBON_BUDGET_G=500
